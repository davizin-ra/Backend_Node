generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id          Int          @id @default(autoincrement())
  nome        String?
  email       String       @unique
  senha       String
  resetTokens resetToken[]
}

model resetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      users    @relation(fields: [userId], references: [id], onUpdate: Restrict)

  @@index([userId], map: "resetToken_userId_fkey")
}
